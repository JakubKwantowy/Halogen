# Halogen brainfuck interpreter (yes it's real) #

0 0x1000 0

0

# Code goes here. #

"-,+[-[>>++++[>++++++++<-]<+<-[>+>+>-[>>>]<[[>+<-]>>+>]<<<<<-]]>>>[-]+>--[-[<->+++[-]]]<[++++++++++++<[>-[>+>>]>[+[<+>-]>+>>]<<<<<-]>>[<+>-]>[-[-<<[-]>>]<<[<<->>-]>>]<<[<<+>>-]]<[-]<.[-]<-,+]"

:totoploc
    2 + top -
;

:getbfptr
    0 totoploc grab
;

:setbfptr
    0xffff & 1 totoploc swap place
;

:getiptr
    1 totoploc grab
;

:setiptr
    2 totoploc swap place
;

:gettmp
    2 totoploc grab
;

:settmp
    3 totoploc swap place
;

:bf_print
    getbfptr peek putc
;

:bf_input
    getbfptr getc poke
;

:bf_add
    getbfptr dup peek
    1 + poke
;

:bf_sub
    getbfptr dup peek
    1 swap - poke
;

:bf_next
    getbfptr
    1 + setbfptr
;

:bf_prev
    1 getbfptr
    - setbfptr
;

:bf_loop
    getbfptr peek bool ~ ( pop
        1 settmp
        1 (
            pop
            getiptr 1 + dup setiptr
            peek dup "[" = ( pop gettmp 1 + settmp 0 ) pop
            "]" = dup ( pop gettmp 1 swap - settmp 0 ) pop
            gettmp bool ~ & ~
        )
    0 ) pop
;

:bf_loopend
    getbfptr peek bool ( pop
        1 settmp
        1 (
            pop
            getiptr 1 swap - dup setiptr
            peek dup "]" = ( pop gettmp 1 + settmp 0 ) pop
            "[" = dup ( pop gettmp 1 swap - settmp 0 ) pop
            gettmp bool ~ & ~
        )
    0 ) pop
;

( getiptr swap poke getiptr 1 + setiptr )

0x1000 setiptr

getiptr peek (
    dup "." = ( pop bf_print 0 ) pop
    dup "," = ( pop bf_input 0 ) pop
    dup "+" = ( pop bf_add 0 ) pop
    dup "-" = ( pop bf_sub 0 ) pop
    dup ">" = ( pop bf_next 0 ) pop
    dup "<" = ( pop bf_prev 0 ) pop
    dup "[" = ( pop bf_loop 0 ) pop
    dup "]" = ( pop bf_loopend 0 ) pop
    pop

    getiptr 1 + setiptr
    getiptr peek
)
